{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Caroline Companion",
  "version": "0.1.0",
  "identifier": "com.projectcaroline.companion",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Caroline",
        "width": 430,
        "height": 620,
        "minWidth": 360,
        "minHeight": 460,
        "resizable": true,
        "transparent": true,
        "shadow": true
      }
    ],
    "security": {
      "csp": "default-src 'none'; script-src 'self'; style-src 'self' 'unsafe-inline'; connect-src ws: wss:; img-src 'self' data: blob:; font-src 'self' data:"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all"
  }
}
