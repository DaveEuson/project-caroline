{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Project Caroline Companion",
  "version": "0.1.10",
  "identifier": "com.projectcaroline.companion",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Project: Caroline",
        "width": 760,
        "height": 660,
        "minWidth": 560,
        "minHeight": 520,
        "resizable": true,
        "transparent": true,
        "shadow": true
      }
    ],
    "security": {
      "csp": "default-src 'none'; script-src 'self'; style-src 'self' 'unsafe-inline'; connect-src ws: wss: https://api.github.com; img-src 'self' data: blob:; font-src 'self' data:"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
