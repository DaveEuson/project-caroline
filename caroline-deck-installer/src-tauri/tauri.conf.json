{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Project Caroline Deck Installer",
  "version": "0.1.0",
  "identifier": "com.projectcaroline.deckinstaller",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1430",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Project: Caroline Deck Installer",
        "width": 1020,
        "height": 720,
        "minWidth": 720,
        "minHeight": 560,
        "resizable": true
      }
    ],
    "security": {
      "csp": "default-src 'none'; script-src 'self'; style-src 'self' 'unsafe-inline'; connect-src http: https:; img-src 'self' data: blob:; font-src 'self' data:"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["appimage", "deb", "rpm"]
  }
}
